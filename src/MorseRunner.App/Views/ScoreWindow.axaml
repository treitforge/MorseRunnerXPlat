<Window
    x:Class="MorseRunner.App.Views.ScoreWindow"
    x:DataType="viewModels:ScoreWindowViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:MorseRunner.App.ViewModels"
    Title="Contest Score"
    Width="560"
    Height="300"
    CanResize="False"
    WindowStartupLocation="CenterOwner"
    Background="#07111B">
  <Grid Margin="28" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="18">
    <TextBlock
        FontSize="25"
        FontWeight="SemiBold"
        Foreground="#7CE7CB"
        Text="Contest score" />
    <TextBlock
        Grid.Row="1"
        Foreground="#91A6B8"
        Text="Your score string is:" />
    <TextBox
        Grid.Row="2"
        AutomationProperties.Name="Score summary"
        FontFamily="Consolas"
        FontSize="16"
        IsReadOnly="True"
        Text="{Binding ScoreString}"
        VerticalContentAlignment="Center" />
    <StackPanel
        Grid.Row="3"
        HorizontalAlignment="Right"
        Orientation="Horizontal"
        Spacing="10">
      <Button
          AutomationProperties.Name="Submit score"
          Content="Submit to server"
          IsEnabled="False"
          ToolTip.Tip="Online score submission is not configured." />
      <Button
          AutomationProperties.Name="View high score page"
          Content="Hi-score web page"
          IsEnabled="False"
          ToolTip.Tip="No score service URL is configured." />
      <Button
          x:Name="CloseButton"
          AutomationProperties.Name="Close score dialog"
          Click="CloseClick"
          Content="Close"
          IsDefault="True" />
    </StackPanel>
  </Grid>
</Window>
