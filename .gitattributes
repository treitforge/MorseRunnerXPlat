# Keep source and automation files consistent on Windows CI and developer machines.
# Audio fixtures remain byte-for-byte data.
* text=auto
.gitattributes text eol=lf
.editorconfig text eol=lf
*.cs text eol=lf
*.csproj text eol=lf
*.slnx text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ps1 text eol=lf
*.py text eol=lf
*.sh text eol=lf
src/MorseRunner.Infrastructure/Data/** -text
